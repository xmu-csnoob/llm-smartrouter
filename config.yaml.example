# ===== Provider Definitions =====
providers:
  glm:
    base_url: "https://open.bigmodel.cn/api/anthropic"
    api_key: "${GLM_API_KEY}"
    api_format: "anthropic"
    timeout: 120

# ===== Model Pool =====
models:
  tier1:  # Frontier: design, refactoring, hard bugs
    - id: "glm-5.1"
      provider: glm

  tier2:  # Workhorse: feature implementation
    - id: "glm-5"
      provider: glm

  tier3:  # Routine: conflicts, compile errors, simple tasks
    - id: "glm-4.7"
      provider: glm

# ===== Routing Rules =====
# When scoring is enabled, matching rules act as bonus signals instead of the
# only decision source. Keep only high-signal rules here.
rules:
  - name: "explicit-model"
    match: "model_is_known"
    action: "passthrough"

  - name: "complex-request"
    match: "estimated_tokens > 4000 or message_count > 20"
    target: tier1

  - name: "keyword-match"
    keywords: ["refactor", "design", "architect", "debug", "fix bug", "root cause", "redesign", "rewrite", "migrate"]
    target: tier1

  - name: "medium-request"
    match: "estimated_tokens > 2000"
    target: tier2

  - name: "default"
    target: tier3

# ===== Request Scoring =====
scoring:
  enabled: true
  legacy_rule_bonus: 2.0
  tiers:
    tier1:
      threshold: 6.0
    tier2:
      threshold: 3.0
  features:
    large_context:
      enabled: true
      thresholds:
        estimated_tokens: 4000
        message_count: 20
      weights:
        tier1: 4.0
        tier2: 1.5
    medium_context:
      enabled: true
      thresholds:
        estimated_tokens: 2000
        message_count: 10
      weights:
        tier2: 3.0
        tier1: 1.0
    architecture_design:
      enabled: true
      thresholds:
        architecture_signal_count: 1
      weights:
        tier1: 4.5
        tier2: 1.0
    debugging:
      enabled: true
      thresholds:
        debug_signal_count: 1
      weights:
        tier1: 3.5
        tier2: 1.0
    implementation:
      enabled: true
      thresholds:
        implementation_signal_count: 1
      weights:
        tier2: 3.0
    generation_heavy:
      enabled: true
      thresholds:
        generation_signal_count: 1
      weights:
        tier2: 3.0
    simple_prompt:
      enabled: true
      thresholds:
        estimated_tokens_max: 600
        message_count_max: 3
      weights:
        tier3: 2.0

# ===== Semantic Features (Schema v3 — data collection only) =====
semantic_features:
  enabled: true
  # Keyword signal extraction for ML router training data
  keyword_signals:
    enabled: true
  # Intent classification priority order
  intent_classifier:
    enabled: true
    priority_order:
      - debug
      - implementation
      - architecture
      - analysis
      - simple
      - general

# ===== ML Routing (Phase 2) =====
ml_routing:
  enabled: false
  model_name: "leftfield7/bert-tiny-llm-router"
  model_cache_dir: "./models/cache"
  manifest_path: "./models/manifest.json"
  inference:
    timeout_ms: 50
    fallback_on_error: true
  weights:
    tier1: 2.0
    tier2: 2.0
    tier3: 2.0

# ===== Redaction (PII masking for logged requests) =====
redaction:
  enabled: true
  redact_paths: true   # Redact file paths to basename only

# ===== Shadow Policy (lower-tier sampling for training data) =====
shadow_policy:
  enabled: false
  # observe_only_rate: 1.0 means 100% observe-only (no forced lower-tier sampling)
  observe_only_rate: 1.0
  forced_tier1_to_tier2_rate: 0.01   # 1% of tier1 requests forced to tier2
  forced_tier2_to_tier3_rate: 0.02  # 2% of tier2 requests forced to tier3
  forbid_direct_tier1_to_tier3: true
  # Hard exclusions — requests matching these are never forced to lower tier
  hard_exclusions:
    stacktrace_count_gte: 1
    code_block_count_gte: 3
    file_path_count_gte: 3
    estimated_tokens_gte: 3500
    message_count_gte: 12
    tool_count_gte: 1
    # streaming_large_output: streaming + max_tokens >= 4096
    # explicit_model_request: matched_by == "passthrough"
    # architecture_task: task_type == "architecture"
    # debug_keywords_detected: debug keywords in request
    # sensitive_info_detected: email/phone/API key patterns

# ===== Fallback / Degradation =====
fallback:
  latency_threshold_ms: 30000
  error_threshold: 3
  cooldown_seconds: 120
  cross_provider: true
  cross_tier: true
  degradation_order: [tier1, tier2, tier3]

# ===== Request Logging =====
logging:
  enabled: true
  dir: "./logs"
  flush_interval_seconds: 2
  flush_batch_size: 50
  retention_days: 30
  archive_dir: "archive"           # Archive subdirectory name (relative to dir)
  auto_archive_count: 10000       # Auto-archive when entry count exceeds this
  auto_archive_days: 7            # Auto-archive when oldest entry exceeds this (days)

# ===== Server =====
server:
  host: "127.0.0.1"
  port: 8000
  log_level: "info"
